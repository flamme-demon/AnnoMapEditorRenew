<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="using:AnnoMapEditor.Utilities"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.SettingsDialog"
        Title="{l:L Key=settings.title}"
        Width="520" Height="440"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ConceptInk900Brush}"
        Foreground="{DynamicResource ConceptTextBrush}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- Header (concept modale style) -->
        <Border Grid.Row="0" Padding="24,20"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="{l:L Key=settings.atelier}" Classes="t-eyebrow" HorizontalAlignment="Center" />
                <TextBlock Text="{l:L Key=settings.title}" Classes="modal-title" />
                <Border Classes="divider-ornate" Width="160" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Body : ScrollViewer vertical (le contenu peut déborder en hauteur quand
             on ajoutera des sections). HorizontalScrollBarVisibility=Disabled — le
             débordement horizontal qu'on avait avant venait du TextBox path naturellement
             large, qui est maintenant borné par MaxWidth=420. ScrollBar stylé via les
             ressources Fluent dans App.axaml (charte concept). -->
        <ScrollViewer Grid.Row="1" Padding="32,20"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="22">

            <!-- ── Démarrage ── -->
            <StackPanel Spacing="10">
                <TextBlock Text="{l:L Key=settings.startup}" Classes="t-eyebrow" />
                <CheckBox x:Name="AutoStartCheckBox"
                          IsCheckedChanged="OnAutoStartToggled"
                          Foreground="{DynamicResource ConceptTextBrush}">
                    <StackPanel Spacing="2">
                        <TextBlock Text="{l:L Key=start.autostart}" FontSize="13" />
                        <TextBlock Text="{l:L Key=start.autostart_help}"
                                   Foreground="{DynamicResource ConceptTextMuteBrush}"
                                   FontSize="11" />
                    </StackPanel>
                </CheckBox>
            </StackPanel>

            <Border Classes="divider-ornate" />

            <!-- ── Dossier du jeu ── -->
            <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="{l:L Key=settings.game_folder}" Classes="t-eyebrow"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="btn ghost sm"
                            Content="{l:L Key=settings.browse}" Click="OnBrowseClicked" />
                </Grid>
                <!-- TextBox éditable. Width plafonné explicitement à 420 (= 520
                     Window - 32*2 padding - quelques pixels d'air) pour éviter le
                     débordement à droite : Avalonia n'impose pas la contrainte de
                     largeur du parent au TextBox quand son contenu (path long) est
                     plus large que MinWidth. -->
                <TextBox x:Name="GamePathBox" Classes="input"
                         TextWrapping="Wrap" AcceptsReturn="False"
                         Height="64" MaxWidth="420"
                         FontFamily="{StaticResource MonoFont}" FontSize="11"
                         VerticalContentAlignment="Top" />
            </StackPanel>
        </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,16"
                Background="{DynamicResource ConceptInk950Brush}"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{l:L Key=settings.live_save}"
                           Foreground="{DynamicResource ConceptTextMuteBrush}"
                           FontSize="11" FontStyle="Italic"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="btn primary"
                        Content="{l:L Key=settings.close}" Click="OnCloseClicked" />
            </Grid>
        </Border>
    </Grid>
</Window>
