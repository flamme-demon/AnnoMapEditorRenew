<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.NewModWizardDialog"
        Title="Nouveau mod"
        Width="640" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ConceptInk900Brush}"
        Foreground="{DynamicResource ConceptTextBrush}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- Header (concept modale style) -->
        <Border Grid.Row="0" Padding="24,20"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="ATELIER" Classes="t-eyebrow" HorizontalAlignment="Center" />
                <TextBlock Text="Créer un nouveau mod" Classes="modal-title" />
                <Border Classes="divider-ornate" Width="160" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Body (scrollable form) -->
        <ScrollViewer Grid.Row="1" Padding="32,20">
            <StackPanel Spacing="16">

                <!-- Mod name -->
                <StackPanel Spacing="6">
                    <TextBlock Text="NOM DU MOD" Classes="t-eyebrow" />
                    <TextBox Classes="input" Watermark="ex: Four Corner Battle" />
                </StackPanel>

                <!-- Mod ID -->
                <StackPanel Spacing="6">
                    <TextBlock Text="IDENTIFIANT TECHNIQUE (AUTO)" Classes="t-eyebrow" />
                    <TextBox Classes="input" Text="ame-four-corner-battle" IsReadOnly="True"
                             Foreground="{DynamicResource ConceptTextDimBrush}" />
                </StackPanel>

                <!-- Type de carte -->
                <StackPanel Spacing="6">
                    <TextBlock Text="TYPE DE CARTE" Classes="t-eyebrow" />
                    <ComboBox Classes="input" SelectedIndex="0" HorizontalAlignment="Stretch">
                        <ComboBoxItem>Corners (4 quadrants)</ComboBoxItem>
                        <ComboBoxItem>Chain (chaîne d'îles)</ComboBoxItem>
                        <ComboBoxItem>Donut (anneau)</ComboBoxItem>
                        <ComboBoxItem>Default (libre)</ComboBoxItem>
                        <ComboBoxItem>Personnalisé…</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <Border Classes="divider-ornate" />

                <!-- Régions -->
                <StackPanel Spacing="6">
                    <TextBlock Text="RÉGIONS À SUPPORTER" Classes="t-eyebrow" />
                    <TextBlock Text="Un variant sera généré pour chaque région cochée."
                               Foreground="{DynamicResource ConceptTextDimBrush}" FontSize="11" />
                    <Grid ColumnDefinitions="*,*,*">
                        <CheckBox Grid.Column="0" Content="Latium (Roman)" IsChecked="True"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                        <CheckBox Grid.Column="1" Content="Albion (Celtic)"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                        <CheckBox Grid.Column="2" Content="Désert (DLC)" IsEnabled="False"
                                  Foreground="{DynamicResource ConceptTextMuteBrush}"
                                  ToolTip.Tip="DLC à venir" />
                    </Grid>
                </StackPanel>

                <!-- Difficultés -->
                <StackPanel Spacing="6">
                    <TextBlock Text="DIFFICULTÉS À GÉNÉRER" Classes="t-eyebrow" />
                    <Grid ColumnDefinitions="*,*,*">
                        <CheckBox Grid.Column="0" Content="Facile" IsChecked="True"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                        <CheckBox Grid.Column="1" Content="Normal" IsChecked="True"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                        <CheckBox Grid.Column="2" Content="Difficile"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                    </Grid>
                </StackPanel>

                <!-- Tailles -->
                <StackPanel Spacing="6">
                    <TextBlock Text="TAILLES" Classes="t-eyebrow" />
                    <Grid ColumnDefinitions="*,*">
                        <CheckBox Grid.Column="0" Content="2048 (vanilla)" IsChecked="True"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                        <CheckBox Grid.Column="1" Content="2688 (DLC1 expanded)" IsChecked="True"
                                  Foreground="{DynamicResource ConceptTextBrush}" />
                    </Grid>
                </StackPanel>

                <Border Classes="divider-ornate" />

                <!-- Récap -->
                <Border CornerRadius="6" Padding="14,10"
                        Background="{DynamicResource ConceptInk950Brush}"
                        BorderBrush="{DynamicResource ConceptGold700Brush}"
                        BorderThickness="1">
                    <StackPanel Spacing="6">
                        <TextBlock Text="RÉCAPITULATIF" Classes="t-eyebrow" />
                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                   Foreground="{DynamicResource ConceptGold300Brush}"
                                   Text="4 variants seront créés : Latium Easy 2048, Latium Easy 2688, Latium Medium 2048, Latium Medium 2688." />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,16"
                Background="{DynamicResource ConceptInk950Brush}"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Text="POC — données mock"
                           Foreground="{DynamicResource ConceptTextMuteBrush}"
                           FontStyle="Italic" FontSize="11"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="btn secondary"
                        Content="Annuler" Margin="0,0,8,0" Click="OnCancelClick" />
                <Button Grid.Column="2" Classes="btn primary"
                        Content="Créer le mod" Click="OnCreateClick" />
            </Grid>
        </Border>
    </Grid>
</Window>
