<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AnnoMapEditor.UI.Avalonia.ViewModels"
        xmlns:c="using:AnnoMapEditor.UI.Avalonia.Controls"
        xmlns:l="using:AnnoMapEditor.Utilities"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.MainWindow"
        Title="{l:L Key=app.title}"
        Width="1280" Height="820"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0" Padding="20,14" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <TextBlock Text="{l:L Key=app.tagline}" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="GameTitle" Opacity="0.7" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="{l:L Key=main.save_mod}" Click="OnSaveModClicked"
                            x:Name="SaveModButton" IsEnabled="False"
                            Classes="accent" />
                    <Button Content="{l:L Key=main.back_to_start}" Click="OnBackToStart" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="380,*,320">

            <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Row="0" Margin="20,16,20,8" FontSize="16" FontWeight="SemiBold"
                           Text="{l:L Key=main.maps_title}" />

                <ItemsControl Grid.Row="1" Margin="20,0,20,8" x:Name="DlcFilters">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DlcFilter">
                            <ToggleButton Content="{Binding Label}"
                                          IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                          Margin="0,0,6,6"
                                          Padding="10,4"
                                          FontSize="12" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Row="2" Margin="20,0,20,8" Opacity="0.6" FontSize="12"
                           x:Name="MapsCountLabel" />

                <TreeView Grid.Row="3" Margin="20,0,20,8" x:Name="MapsList"
                          SelectionChanged="OnMapSelected">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate x:DataType="vm:MapListEntry"
                                          ItemsSource="{Binding Children}">
                            <StackPanel Spacing="2" Margin="0,4">
                                <TextBlock Text="{Binding Header}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SubHeader}" FontSize="11" Opacity="0.7" />
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <!-- Session properties (active once a map is loaded). Mirrors the upstream
                     Anno 1800 editor layout: region / map size / playable area size /
                     edit toggle, with the per-edge advanced editor tucked behind an Expander. -->
                <Border Grid.Row="4" x:Name="SessionPropsPanel"
                        BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="0,1,0,0"
                        Padding="20,12" IsVisible="False">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{l:L Key=main.session_section}" FontSize="14" FontWeight="SemiBold" />

                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="{l:L Key=main.session_region}" VerticalAlignment="Center" Opacity="0.7" />
                            <TextBlock Grid.Column="1" x:Name="SessionRegionLabel" FontWeight="SemiBold" />
                        </Grid>

                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="{l:L Key=main.session_map_size}" VerticalAlignment="Center" Opacity="0.7" />
                            <TextBlock Grid.Column="1" x:Name="SessionMapSizeLabel" FontWeight="SemiBold" />
                        </Grid>

                        <Grid ColumnDefinitions="120,*">
                            <TextBlock Grid.Column="0" Text="{l:L Key=main.session_pa_size}" VerticalAlignment="Center" Opacity="0.7" />
                            <Grid Grid.Column="1" ColumnDefinitions="*,Auto">
                                <Slider Grid.Column="0" x:Name="SessionPaSlider" Margin="0,0,8,0"
                                        Minimum="64" Maximum="4096"
                                        ValueChanged="OnSessionPaSliderChanged"
                                        PointerWheelChanged="OnSessionPaSliderWheel" />
                                <TextBlock Grid.Column="1" x:Name="SessionPaSizeLabel"
                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                           MinWidth="50" TextAlignment="Right" />
                            </Grid>
                        </Grid>

                        <CheckBox x:Name="SessionEditPaToggle"
                                  Content="{l:L Key=main.session_edit_pa}"
                                  IsCheckedChanged="OnSessionEditPaToggleChanged" />

                        <!-- Capped height + scroll so a noisy validator (e.g. 40+ issues on
                             Taludas-style maps with many duplicate-position fixed islands)
                             can't push the maps list off screen. -->
                        <Border BorderBrush="{DynamicResource SystemBaseLowColor}" BorderThickness="0,1,0,0"
                                Padding="0,8,0,4">
                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="IssuesPanel" Spacing="2" />
                            </ScrollViewer>
                        </Border>

                        <Expander Header="{l:L Key=main.session_advanced}">
                            <StackPanel Spacing="4" Margin="0,4,0,0">
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="{l:L Key=main.playable_x1}" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" x:Name="PaX1Box" Increment="32" />
                                </Grid>
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="{l:L Key=main.playable_y1}" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" x:Name="PaY1Box" Increment="32" />
                                </Grid>
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="{l:L Key=main.playable_x2}" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" x:Name="PaX2Box" Increment="32" />
                                </Grid>
                                <Grid ColumnDefinitions="100,*">
                                    <TextBlock Grid.Column="0" Text="{l:L Key=main.playable_y2}" VerticalAlignment="Center" />
                                    <NumericUpDown Grid.Column="1" x:Name="PaY2Box" Increment="32" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <Button Content="{l:L Key=main.playable_apply}" Click="OnApplyPlayableArea" Classes="accent" />
                                    <Button Content="{l:L Key=main.playable_reset}" Click="OnResetPlayableArea" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*">
                <StackPanel Grid.Row="0" Margin="20,16,20,0" Spacing="4">
                    <TextBlock x:Name="MapDetailTitle" FontSize="18" FontWeight="SemiBold"
                               Text="{l:L Key=main.select_map_hint}" />
                    <TextBlock x:Name="MapDetailSubtitle" Opacity="0.7" FontSize="12" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,*,Auto,*"
                      Margin="20,12,20,8" x:Name="MapStatsGrid">
                    <TextBlock Grid.Column="0" Text="{l:L Key=main.size}" Opacity="0.6" />
                    <TextBlock Grid.Column="1" x:Name="StatSize" FontWeight="SemiBold" Margin="6,0,0,0" />
                    <TextBlock Grid.Column="2" Text="{l:L Key=main.playable_area}" Opacity="0.6" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="3" x:Name="StatPlayable" FontWeight="SemiBold" Margin="6,0,0,0" />
                    <TextBlock Grid.Column="4" Text="{l:L Key=main.elements}" Opacity="0.6" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="5" x:Name="StatElements" FontWeight="SemiBold" Margin="6,0,0,0" />
                </Grid>

                <Border Grid.Row="2" BorderBrush="{DynamicResource SystemBaseLowColor}"
                        BorderThickness="1,1,0,0" Margin="20,0,0,0">
                    <c:MapView x:Name="MapRenderer" />
                </Border>
            </Grid>

            <Border Grid.Column="2" BorderBrush="{DynamicResource SystemBaseLowColor}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,Auto,*,Auto,160">

                    <!-- Top: hierarchical tree of map elements grouped by category. Capped at
                         260 px tall (with internal scroll) so a long element list never pushes
                         the Properties panel off-screen below. -->
                    <Grid Grid.Row="0" RowDefinitions="Auto,*" Margin="16,12,16,8">
                        <TextBlock Grid.Row="0" Text="{l:L Key=main.tree_title}"
                                   FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />
                        <ScrollViewer Grid.Row="1" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                            <TreeView x:Name="ElementsTree"
                                      SelectionChanged="OnTreeSelectionChanged">
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate x:DataType="vm:MapElementNode"
                                                      ItemsSource="{Binding Children}">
                                        <TextBlock Text="{Binding Label}"
                                                   FontWeight="{Binding IsCategory,
                                                       Converter={x:Static l:BoolToFontWeight.Instance}}" />
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Row="1" BorderBrush="{DynamicResource SystemBaseLowColor}"
                            BorderThickness="0,1,0,0" />

                    <!-- Middle: properties panel for the selected element. Always-visible
                         scrollbar so the user knows the panel is scrollable, even on short
                         content (avoids the "where is the scrollbar?" surprise on randoms). -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Visible" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{l:L Key=main.properties}" FontSize="14" FontWeight="SemiBold" />
                            <TextBlock x:Name="SelHint" Opacity="0.6" FontSize="12"
                                       Text="{l:L Key=main.no_selection_hint}" />
                            <StackPanel x:Name="ActionButtons" Orientation="Horizontal" IsVisible="False">
                                <Button Content="{l:L Key=main.duplicate}" Click="OnDuplicateClicked"
                                        Padding="8,4" Margin="0,0,4,0" ToolTip.Tip="Ctrl+D" />
                                <Button x:Name="RotateButton" Content="{l:L Key=main.rotate}" Click="OnRotateClicked"
                                        Padding="8,4" Margin="0,0,4,0" ToolTip.Tip="R" />
                                <Button Content="{l:L Key=main.delete}" Click="OnDeleteClicked"
                                        Padding="8,4" ToolTip.Tip="Suppr" />
                            </StackPanel>
                            <StackPanel x:Name="SelProperties" Spacing="6" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="3" BorderBrush="{DynamicResource SystemBaseLowColor}"
                            BorderThickness="0,1,0,0" />

                    <!-- Bottom: history. -->
                    <Grid Grid.Row="4" RowDefinitions="Auto,*" Margin="16,8,16,12">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0" Text="{l:L Key=main.history}" FontSize="14"
                                       FontWeight="SemiBold" VerticalAlignment="Center" />
                            <Button Grid.Column="1" x:Name="UndoButton" Content="{l:L Key=main.undo}"
                                    Click="OnUndoClicked" Padding="8,2" Margin="0,0,4,0"
                                    ToolTip.Tip="Ctrl+Z" />
                            <Button Grid.Column="2" x:Name="RedoButton" Content="{l:L Key=main.redo}"
                                    Click="OnRedoClicked" Padding="8,2"
                                    ToolTip.Tip="Ctrl+Y" />
                        </Grid>
                        <ListBox Grid.Row="1" x:Name="HistoryList" Margin="0,8,0,0"
                                 SelectionChanged="OnHistoryItemSelected" />
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <Border Grid.Row="2" Padding="20,8" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <TextBlock x:Name="StatusBar" Opacity="0.7" FontSize="12" />
        </Border>

    </Grid>
</Window>
