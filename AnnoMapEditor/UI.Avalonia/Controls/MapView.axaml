<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AnnoMapEditor.UI.Avalonia.Controls.MapView"
             Background="{DynamicResource AnnoBgBrush}"
             ClipToBounds="True">
    <Grid>
        <ScrollViewer x:Name="Scroller"
                      Background="Transparent"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      AllowAutoHide="False">
            <LayoutTransformControl x:Name="ZoomHost" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Canvas x:Name="MapCanvas" Width="0" Height="0" Background="#082236" />
            </LayoutTransformControl>
        </ScrollViewer>

        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="12" Padding="10,6"
                Background="#80000000" CornerRadius="4">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock x:Name="ZoomLabel" Foreground="White" FontSize="11" />
                <Button Content="−" Click="OnZoomOut" Padding="6,0" />
                <Button Content="+" Click="OnZoomIn"  Padding="6,0" />
                <Button Content="Reset" Click="OnZoomReset" Padding="6,0" />
                <Button x:Name="OrientationBtn" Content="◇ Vue jeu"
                        Click="OnRotateView" Padding="6,0"
                        ToolTip.Tip="Bascule entre la vue à plat (0°) et la vue losange du jeu (45°, nord en haut)" />
            </StackPanel>
        </Border>

        <TextBlock x:Name="EmptyHint" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Opacity="0.5" Text="Sélectionne une carte à gauche" />
    </Grid>
</UserControl>
