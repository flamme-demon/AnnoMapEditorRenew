<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AnnoMapEditor.UI.Avalonia.ViewModels"
        xmlns:c="using:AnnoMapEditor.UI.Avalonia.Controls"
        xmlns:l="using:AnnoMapEditor.Utilities"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.MainWindow"
        Title="{l:L Key=app.title}"
        Width="1440" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ConceptInk900Brush}"
        Foreground="{DynamicResource ConceptTextBrush}">

    <!-- =====================================================================
         Anno 117 Map Template Editor — port fidèle de
         `AnnoMap Design/src/Editor.jsx` (lang=fr).
         Layout vertical : Header / Biome bar / Body 3 colonnes.
         Tous les x:Name référencés par le code-behind sont préservés ; ceux
         qui n'apparaissent pas dans le concept sont conservés dans un
         Border IsVisible="False" en bas du Grid pour ne pas casser le .cs.
         ===================================================================== -->

    <Grid>
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- =================================================================
                 [HEADER] Editor.jsx 430-477 — logo + title + status pill + actions
                 ================================================================= -->
            <Border Grid.Row="0"
                    Padding="16,8"
                    BorderBrush="{DynamicResource ConceptBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Offset="0.0" Color="{StaticResource ConceptInk800}" />
                        <GradientStop Offset="1.0" Color="{StaticResource ConceptInk900}" />
                    </LinearGradientBrush>
                </Border.Background>

                <Grid ColumnDefinitions="Auto,Auto,*,Auto,*,Auto" VerticalAlignment="Center">

                    <!-- Logo SVG (Editor.jsx Logo : losange orné, gold-500) -->
                    <Canvas Grid.Column="0" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,12,0">
                        <Path Stroke="{DynamicResource ConceptGold500Brush}" StrokeThickness="1.4"
                              Data="M 12 2.25 L 21.75 12 L 12 21.75 L 2.25 12 Z" />
                        <Path Stroke="{DynamicResource ConceptGold500Brush}" StrokeThickness="1.4" Opacity="0.55"
                              Data="M 12 6 L 18 12 L 12 18 L 6 12 Z" />
                        <Ellipse Canvas.Left="10.5" Canvas.Top="10.5" Width="3" Height="3"
                                 Fill="{DynamicResource ConceptGold500Brush}" />
                    </Canvas>

                    <!-- Bloc titre : eyebrow + display title -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="ANNO 117" Classes="t-display"
                                   FontSize="12" Foreground="{DynamicResource ConceptGold300Brush}"
                                   LetterSpacing="2" />
                        <TextBlock x:Name="GameTitle" Text="Anno Mod Creator"
                                   Classes="t-mute" FontSize="9" LetterSpacing="1.6" />
                    </StackPanel>

                    <!-- Status pill central (DiamondOrnament + texte) -->
                    <Border Grid.Column="3"
                            Padding="14,5"
                            CornerRadius="999"
                            Background="{DynamicResource ConceptInk950Brush}"
                            BorderBrush="{DynamicResource ConceptBorderBrush}"
                            BorderThickness="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Canvas Width="8" Height="8" VerticalAlignment="Center">
                                <Path Stroke="{DynamicResource ConceptGold700Brush}" StrokeThickness="1"
                                      Data="M 4 0.6 L 7.4 4 L 4 7.4 L 0.6 4 Z" />
                                <Ellipse Canvas.Left="2.8" Canvas.Top="2.8" Width="2.4" Height="2.4"
                                         Fill="{DynamicResource ConceptGold700Brush}" />
                            </Canvas>
                            <TextBlock x:Name="StatusBar"
                                       Text="3 cartes requises par biome"
                                       Foreground="{DynamicResource ConceptTextDimBrush}"
                                       FontSize="10" LetterSpacing="0.6"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <!-- Actions à droite (Editor.jsx 463-476) -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center">
                        <Button Classes="btn secondary sm" Content="✦  Nouvelle" />
                        <Button Classes="btn secondary sm" Content="⇣  Importer du jeu" />
                        <Border Width="1" Height="18" Margin="2,0"
                                Background="{DynamicResource ConceptBorderBrush}" />
                        <Button x:Name="SaveModButton" Classes="btn secondary sm"
                                Content="💾  Sauvegarder"
                                Click="OnSaveModClicked" IsEnabled="False" />
                        <Button Classes="btn ghost sm icon" Content="🖼"
                                ToolTip.Tip="Exporter PNG" />
                        <Button Classes="btn primary sm" Content="⇡  Exporter le mod" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- =================================================================
                 [BIOME BAR] Editor.jsx 480-576 — biomes + map tabs + diff badge
                 ================================================================= -->
            <Border Grid.Row="1"
                    Padding="16,8"
                    Background="{DynamicResource ConceptInk800Brush}"
                    BorderBrush="{DynamicResource ConceptBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto" VerticalAlignment="Center">

                    <!-- Biomes (RadioButton.biome-tab) -->
                    <RadioButton Grid.Column="0" Classes="biome-tab" GroupName="Biome"
                                 IsChecked="True" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Glyphe Latium (losange/diamant) -->
                            <Canvas Width="14" Height="14" VerticalAlignment="Center">
                                <Path Stroke="{DynamicResource ConceptGold300Brush}" StrokeThickness="1.2"
                                      Data="M 7 1.7 L 12.3 7 L 7 12.3 L 1.7 7 Z" />
                                <Path Stroke="{DynamicResource ConceptGold300Brush}" StrokeThickness="1.2" Opacity="0.7"
                                      Data="M 7 4.7 L 9.3 7 L 7 9.3 L 4.7 7 Z" />
                                <Ellipse Canvas.Left="6.3" Canvas.Top="6.3" Width="1.4" Height="1.4"
                                         Fill="{DynamicResource ConceptGold300Brush}" />
                            </Canvas>
                            <TextBlock Text="Latium" VerticalAlignment="Center" />
                            <Border Padding="5,1" CornerRadius="999"
                                    Background="{DynamicResource ConceptInk950Brush}">
                                <TextBlock Text="0/3" Classes="t-mono" FontSize="9"
                                           Foreground="{DynamicResource ConceptGold400Brush}" />
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Grid.Column="1" Classes="biome-tab" GroupName="Biome" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Glyphe Albion (forme abstraite trèfle) -->
                            <Canvas Width="14" Height="14" VerticalAlignment="Center">
                                <Path Stroke="{DynamicResource ConceptGold500Brush}" StrokeThickness="1.2"
                                      Data="M 7 2.3 C 9.3 2.3 11.1 4 11.1 6.4 C 11.1 8.2 9.3 9.3 7.6 9.3 C 6.4 9.3 5.3 8.2 5.3 7 C 5.3 6.4 5.8 5.8 6.4 5.8" />
                                <Path Stroke="{DynamicResource ConceptGold500Brush}" StrokeThickness="1.2"
                                      Data="M 7 11.7 C 4.7 11.7 2.9 10 2.9 7.6 C 2.9 5.8 4.7 4.7 6.4 4.7 C 7.6 4.7 8.7 5.8 8.7 7 C 8.7 7.6 8.2 8.2 7.6 8.2" />
                                </Canvas>
                            <TextBlock Text="Albion" VerticalAlignment="Center" />
                            <Border Padding="5,1" CornerRadius="999"
                                    Background="{DynamicResource ConceptInk950Brush}">
                                <TextBlock Text="0/3" Classes="t-mono" FontSize="9"
                                           Foreground="{DynamicResource ConceptGold400Brush}" />
                            </Border>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Grid.Column="2" Classes="biome-tab" GroupName="Biome"
                                 IsEnabled="False" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="◐" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ConceptTextMuteBrush}" />
                            <TextBlock Text="Désert" VerticalAlignment="Center" />
                            <TextBlock Text="Bientôt" Classes="t-mute" FontSize="9" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Grid.Column="3" Classes="biome-tab" GroupName="Biome"
                                 IsEnabled="False" Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="❄" FontSize="13" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ConceptTextMuteBrush}" />
                            <TextBlock Text="Nordique" VerticalAlignment="Center" />
                            <TextBlock Text="Bientôt" Classes="t-mute" FontSize="9" VerticalAlignment="Center" />
                        </StackPanel>
                    </RadioButton>

                    <!-- Séparateur vertical -->
                    <Border Grid.Column="4" Width="1" Height="24" Margin="0,0,16,0"
                            Background="{DynamicResource ConceptBorderBrush}" />

                    <!-- Map tabs (Editor.jsx 528-553) -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6"
                                VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="CARTE" Classes="t-eyebrow" FontSize="9" VerticalAlignment="Center" />
                        <RadioButton Classes="map-tab" GroupName="Map" IsChecked="True" Content="1" />
                        <RadioButton Classes="map-tab" GroupName="Map" Content="2" />
                        <RadioButton Classes="map-tab" GroupName="Map" Content="3" />
                    </StackPanel>

                    <!-- Difficulty badge à droite (Editor.jsx 557-575) -->
                    <TextBlock Grid.Column="6" Text="DIFFICULTÉ" Classes="t-eyebrow"
                               FontSize="9" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <Border Grid.Column="7" Padding="12,4" CornerRadius="3"
                            Background="#26C8A96A"
                            BorderBrush="{DynamicResource ConceptGold700Brush}"
                            BorderThickness="1">
                        <TextBlock Text="NORMAL" Foreground="{DynamicResource ConceptGold300Brush}"
                                   FontSize="11" LetterSpacing="0.6" />
                    </Border>
                </Grid>
            </Border>

            <!-- =================================================================
                 [BODY] Editor.jsx 579-917 — 3 colonnes : Stats / Canvas / PlaceIslands
                 ================================================================= -->
            <Grid Grid.Row="2" ColumnDefinitions="200,*,240">

                <!-- ──────────── [COL 0] StatsPanel (Editor.jsx 239-280) ──────────── -->
                <Border Grid.Column="0"
                        Padding="10"
                        Background="{DynamicResource ConceptInk800Brush}"
                        BorderBrush="{DynamicResource ConceptBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Border CornerRadius="4"
                            Padding="12,10"
                            BorderBrush="{DynamicResource ConceptBorderBrush}"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                                <GradientStop Offset="0.0" Color="#EB14213a" />
                                <GradientStop Offset="1.0" Color="#EB0d1626" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <StackPanel Spacing="0">
                            <TextBlock Text="STATISTIQUES" Classes="t-eyebrow" FontSize="9" Margin="0,0,0,6" />
                            <Border Classes="divider-ornate" Margin="0,0,0,4" />

                            <!-- Rows -->
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Standard" Foreground="{DynamicResource ConceptTextBrush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="11">
                                    <Run Text="0" /><Run Text=" " /><Run Foreground="#6e6858" Text="(0S 0M 0L 0XL)" />
                                </TextBlock>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Starter" Foreground="{DynamicResource ConceptGold500Brush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0 / 4" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="11" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="3rd Party" Foreground="#9a7ab0" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="11" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Pirate" Foreground="#a85c5c" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="11" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Vulkan" Foreground="#d68a3c" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="11" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Continental" Foreground="#6a8a5c" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="11" />
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ConceptBorderBrush}" Margin="0,6,0,6" />
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Spawns navire" Foreground="{DynamicResource ConceptTextDimBrush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0 / 4" Classes="t-mono"
                                           Foreground="#5e7fb0" FontSize="11" />
                            </Grid>

                            <Border Height="1" Background="{DynamicResource ConceptGold700Brush}" Margin="0,6,0,6" Opacity="0.6" />
                            <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                                <TextBlock Text="Total" Foreground="{DynamicResource ConceptGold300Brush}" FontSize="11" />
                                <TextBlock Grid.Column="1" Text="0" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold300Brush}" FontSize="11" />
                            </Grid>

                            <!-- Map detail compact (réutilise les x:Name attendus par le code-behind) -->
                            <Border Classes="divider-ornate" />
                            <TextBlock Text="CARTE COURANTE" Classes="t-eyebrow" FontSize="9" />
                            <TextBlock x:Name="MapDetailTitle" Text="—"
                                       Foreground="{DynamicResource ConceptTextBrush}" FontSize="12"
                                       FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0" />
                            <TextBlock x:Name="MapDetailSubtitle" Classes="t-mute" FontSize="10"
                                       TextWrapping="Wrap" Margin="0,1,0,4" />
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                <TextBlock Text="Taille" Foreground="{DynamicResource ConceptTextDimBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" x:Name="StatSize" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="10" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                <TextBlock Text="Zone jouable" Foreground="{DynamicResource ConceptTextDimBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" x:Name="StatPlayable" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="10" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                                <TextBlock Text="Éléments" Foreground="{DynamicResource ConceptTextDimBrush}" FontSize="10" />
                                <TextBlock Grid.Column="1" x:Name="StatElements" Classes="t-mono"
                                           Foreground="{DynamicResource ConceptGold400Brush}" FontSize="10" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- ──────────── [COL 1] Canvas central (Editor.jsx 593-814) ──────────── -->
                <Grid Grid.Column="1" ClipToBounds="True">
                    <!-- Background radial (Editor.jsx 597) -->
                    <Grid.Background>
                        <RadialGradientBrush Center="50%,50%" GradientOrigin="50%,50%"
                                             RadiusX="100%" RadiusY="100%">
                            <GradientStop Offset="0.0" Color="#2a3850" />
                            <GradientStop Offset="1.0" Color="{StaticResource ConceptInk950}" />
                        </RadialGradientBrush>
                    </Grid.Background>

                    <!-- Wrapper carré centré (taille fixe pour l'instant — concept utilise min(82%,720px)) -->
                    <Grid Width="640" Height="640" HorizontalAlignment="Center" VerticalAlignment="Center">

                        <!-- ──────────────────────────────────────────────────────
                             Le losange : carré 453x453 tourné -45°, border gold-700,
                             fond #1f2d48 (Editor.jsx 612-639). Cadre PUREMENT
                             décoratif — le rendu réel des îles est posé par-dessus
                             en carré droit (cf bloc MapView ci-dessous).
                             ────────────────────────────────────────────────────── -->
                        <Border Width="453" Height="453"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#1f2d48"
                                BorderBrush="{DynamicResource ConceptGold700Brush}"
                                BorderThickness="2"
                                BoxShadow="0 20 60 0 #99000000"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <RotateTransform Angle="-45" />
                            </Border.RenderTransform>

                            <!-- Liseré violet inset (Editor.jsx 626-630) -->
                            <Border Margin="6"
                                    BorderBrush="#8a4ca8"
                                    BorderThickness="1"
                                    Opacity="0.6">
                                <!-- Grille isométrique 5×5 (Editor.jsx 632-639). 8 traits
                                     gold-blue subtle. Path Stretch="Fill" pour qu'elle
                                     s'adapte à la taille du losange. -->
                                <Border Margin="6">
                                    <Path Stroke="#5a7290" StrokeThickness="0.5" Opacity="0.3"
                                          Stretch="Fill"
                                          Data="M 0,2 L 10,2  M 0,4 L 10,4  M 0,6 L 10,6  M 0,8 L 10,8
                                                M 2,0 L 2,10  M 4,0 L 4,10  M 6,0 L 6,10  M 8,0 L 8,10" />
                                </Border>
                            </Border>
                        </Border>

                        <!-- ──────────────────────────────────────────────────────
                             MapView (rendu BBDom des îles) posé DROIT au centre du
                             losange. Carré inscrit dans le losange : taille
                             ≈ 453/√2 ≈ 320, qu'on arrondit à 312 pour laisser un
                             peu d'air avec les liserés. ClipToBounds : si le rendu
                             dépasse, c'est tronqué proprement.
                             ────────────────────────────────────────────────────── -->
                        <Border Width="312" Height="312"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                ClipToBounds="True">
                            <c:MapView x:Name="MapRenderer" />
                        </Border>

                        <!-- Marqueurs cardinaux N/E/S/W (Editor.jsx 658-676) -->
                        <Border Width="28" Height="28" CornerRadius="14"
                                BorderBrush="{DynamicResource ConceptGold500Brush}" BorderThickness="1"
                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                Margin="0,-14,0,0">
                            <Border.Background>
                                <RadialGradientBrush Center="30%,25%" GradientOrigin="30%,25%"
                                                     RadiusX="50%" RadiusY="50%">
                                    <GradientStop Offset="0.0" Color="{StaticResource ConceptInk700}" />
                                    <GradientStop Offset="1.0" Color="{StaticResource ConceptInk900}" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <TextBlock Text="N" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource ConceptGold300Brush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="28" Height="28" CornerRadius="14"
                                BorderBrush="{DynamicResource ConceptGold500Brush}" BorderThickness="1"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0,0,-14,0">
                            <Border.Background>
                                <RadialGradientBrush Center="30%,25%" GradientOrigin="30%,25%"
                                                     RadiusX="50%" RadiusY="50%">
                                    <GradientStop Offset="0.0" Color="{StaticResource ConceptInk700}" />
                                    <GradientStop Offset="1.0" Color="{StaticResource ConceptInk900}" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <TextBlock Text="E" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource ConceptGold300Brush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="28" Height="28" CornerRadius="14"
                                BorderBrush="{DynamicResource ConceptGold500Brush}" BorderThickness="1"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                Margin="0,0,0,-14">
                            <Border.Background>
                                <RadialGradientBrush Center="30%,25%" GradientOrigin="30%,25%"
                                                     RadiusX="50%" RadiusY="50%">
                                    <GradientStop Offset="0.0" Color="{StaticResource ConceptInk700}" />
                                    <GradientStop Offset="1.0" Color="{StaticResource ConceptInk900}" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <TextBlock Text="S" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource ConceptGold300Brush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Width="28" Height="28" CornerRadius="14"
                                BorderBrush="{DynamicResource ConceptGold500Brush}" BorderThickness="1"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Margin="-14,0,0,0">
                            <Border.Background>
                                <RadialGradientBrush Center="30%,25%" GradientOrigin="30%,25%"
                                                     RadiusX="50%" RadiusY="50%">
                                    <GradientStop Offset="0.0" Color="{StaticResource ConceptInk700}" />
                                    <GradientStop Offset="1.0" Color="{StaticResource ConceptInk900}" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <TextBlock Text="W" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="SemiBold" FontSize="11"
                                       Foreground="{DynamicResource ConceptGold300Brush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <!-- Toggle "Show island images" top-left (Editor.jsx 798-813) -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="14"
                            Padding="10,6" CornerRadius="4"
                            Background="#EB0d1626"
                            BorderBrush="{DynamicResource ConceptBorderBrush}"
                            BorderThickness="1">
                        <CheckBox IsChecked="True" FontSize="10"
                                  Foreground="{DynamicResource ConceptTextDimBrush}">
                            <TextBlock Text="Images d'îles" />
                        </CheckBox>
                    </Border>

                    <!-- Légende bottom-left (Editor.jsx 752-778) -->
                    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="14"
                            Padding="12,8" CornerRadius="4"
                            Background="#EB0d1626"
                            BorderBrush="{DynamicResource ConceptBorderBrush}"
                            BorderThickness="1">
                        <Grid ColumnDefinitions="Auto,16,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="TAILLE" Classes="t-eyebrow" FontSize="8" Margin="0,0,0,2" />
                                <TextBlock FontSize="10">
                                    <Run Foreground="#d8bf83" Text="S" /><Run Text=" Small" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#d8bf83" Text="M" /><Run Text=" Medium" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#d8bf83" Text="L" /><Run Text=" Large" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#d8bf83" Text="XL" /><Run Text=" Extra Large" Foreground="#a8a090" />
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="2">
                                <TextBlock Text="TYPE" Classes="t-eyebrow" FontSize="8" Margin="0,0,0,2" />
                                <TextBlock FontSize="10">
                                    <Run Foreground="#8a9cb0" Text="N" /><Run Text=" Normal" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#c8a96a" Text="S" /><Run Text=" Starter" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#a85c5c" Text="P" /><Run Text=" Pirate" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#9a7ab0" Text="T" /><Run Text=" 3rd Party" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#d68a3c" Text="V" /><Run Text=" Vulkan" Foreground="#a8a090" />
                                </TextBlock>
                                <TextBlock FontSize="10">
                                    <Run Foreground="#6a8a5c" Text="C" /><Run Text=" Continental" Foreground="#a8a090" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Contrôles bottom-right (Editor.jsx 781-795) -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="14"
                            Padding="12,8" CornerRadius="4"
                            Background="#EB0d1626"
                            BorderBrush="{DynamicResource ConceptBorderBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="2">
                            <TextBlock Text="CONTRÔLES" Classes="t-eyebrow" FontSize="8" Margin="0,0,0,2" />
                            <TextBlock Text="Molette · Zoom" Classes="t-dim" FontSize="10" />
                            <TextBlock Text="Ctrl + Molette · Pan ↑↓" Classes="t-dim" FontSize="10" />
                            <TextBlock Text="Shift + Molette · Pan ←→" Classes="t-dim" FontSize="10" />
                            <TextBlock Text="Bouton du milieu · Pan" Classes="t-dim" FontSize="10" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ──────────── [COL 2] Place Islands (Editor.jsx 817-916) ──────────── -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ConceptInk800Brush}"
                        BorderBrush="{DynamicResource ConceptBorderBrush}"
                        BorderThickness="1,0,0,0">
                    <Grid RowDefinitions="Auto,*">

                        <!-- Titre du biome courant -->
                        <Border Grid.Row="0" Padding="14,12"
                                BorderBrush="{DynamicResource ConceptBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Canvas Width="18" Height="18" VerticalAlignment="Center">
                                    <Path Stroke="{DynamicResource ConceptGold400Brush}" StrokeThickness="1.4"
                                          Data="M 9 2.25 L 15.75 9 L 9 15.75 L 2.25 9 Z" />
                                    <Path Stroke="{DynamicResource ConceptGold400Brush}" StrokeThickness="1.4" Opacity="0.7"
                                          Data="M 9 6 L 12 9 L 9 12 L 6 9 Z" />
                                    <Ellipse Canvas.Left="8.1" Canvas.Top="8.1" Width="1.8" Height="1.8"
                                             Fill="{DynamicResource ConceptGold400Brush}" />
                                </Canvas>
                                <TextBlock Text="LATIUM" Classes="t-display"
                                           FontSize="14" Foreground="{DynamicResource ConceptGold300Brush}"
                                           LetterSpacing="2" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="6">
                                <TextBlock Text="PLACER UNE ÎLE" Classes="t-eyebrow" Margin="0,0,0,4" />

                                <!-- PlaceRow Spawn -->
                                <Grid ColumnDefinitions="60,*" Margin="0,0,0,2">
                                    <TextBlock Grid.Column="0" Text="Spawn"
                                               FontFamily="{StaticResource DisplayFont}" FontSize="10"
                                               LetterSpacing="0.6"
                                               Foreground="{DynamicResource ConceptTextDimBrush}"
                                               TextAlignment="Right" Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1" Classes="place-btn filled"
                                            BorderBrush="#5e7fb0" Content="⚓" />
                                </Grid>

                                <!-- PlaceRow Starter -->
                                <Grid ColumnDefinitions="60,*" Margin="0,0,0,2">
                                    <TextBlock Grid.Column="0" Text="Starter"
                                               FontFamily="{StaticResource DisplayFont}" FontSize="10"
                                               LetterSpacing="0.6"
                                               Foreground="{DynamicResource ConceptTextDimBrush}"
                                               TextAlignment="Right" Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Classes="place-btn" BorderBrush="#c8a96a" Content="L" />
                                        <Button Classes="place-btn" BorderBrush="#c8a96a" Content="XL" />
                                    </StackPanel>
                                </Grid>

                                <!-- PlaceRow Normal -->
                                <Grid ColumnDefinitions="60,*" Margin="0,0,0,2">
                                    <TextBlock Grid.Column="0" Text="Normal"
                                               FontFamily="{StaticResource DisplayFont}" FontSize="10"
                                               LetterSpacing="0.6"
                                               Foreground="{DynamicResource ConceptTextDimBrush}"
                                               TextAlignment="Right" Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Classes="place-btn" Content="S" />
                                        <Button Classes="place-btn" Content="M" />
                                        <Button Classes="place-btn" Content="L" />
                                        <Button Classes="place-btn" Content="XL" />
                                    </StackPanel>
                                </Grid>

                                <!-- PlaceRow NPCs -->
                                <Grid ColumnDefinitions="60,*" Margin="0,0,0,2">
                                    <TextBlock Grid.Column="0" Text="NPCs"
                                               FontFamily="{StaticResource DisplayFont}" FontSize="10"
                                               LetterSpacing="0.6"
                                               Foreground="{DynamicResource ConceptTextDimBrush}"
                                               TextAlignment="Right" Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Classes="place-btn" BorderBrush="#9a7ab0" Content="3rd Party" />
                                        <Button Classes="place-btn" BorderBrush="#a85c5c" Content="Pirate" />
                                    </StackPanel>
                                </Grid>

                                <!-- PlaceRow Vulkan -->
                                <Grid ColumnDefinitions="60,*" Margin="0,0,0,2">
                                    <TextBlock Grid.Column="0" Text="Vulkan"
                                               FontFamily="{StaticResource DisplayFont}" FontSize="10"
                                               LetterSpacing="0.6"
                                               Foreground="{DynamicResource ConceptTextDimBrush}"
                                               TextAlignment="Right" Margin="0,0,8,0"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                        <Button Classes="place-btn" BorderBrush="#d68a3c" Content="S" />
                                        <Button Classes="place-btn" BorderBrush="#d68a3c" Content="M" />
                                    </StackPanel>
                                </Grid>

                                <Button Classes="btn secondary sm block" Content="Île personnalisée…"
                                        Margin="0,8,0,0" />

                                <!-- Compteur Starter (Editor.jsx 900-913) -->
                                <Border Margin="0,8,0,0" Padding="10,8" CornerRadius="4"
                                        Background="{DynamicResource ConceptInk950Brush}"
                                        BorderBrush="{DynamicResource ConceptGold700Brush}"
                                        BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Text="✓ Starter" FontSize="11"
                                                   Foreground="{DynamicResource ConceptGold300Brush}" />
                                        <TextBlock Grid.Column="1" Text="0 / 4" Classes="t-mono" FontSize="11"
                                                   Foreground="{DynamicResource ConceptGold300Brush}" />
                                    </Grid>
                                </Border>

                                <!-- Selection panel (visible quand sélection active) — réutilise les
                                     x:Name attendus par le code-behind -->
                                <TextBlock x:Name="SelHint" Classes="t-mute" FontSize="11"
                                           Margin="0,12,0,0"
                                           Text="{l:L Key=main.no_selection_hint}" />
                                <StackPanel x:Name="ActionButtons" Orientation="Horizontal" IsVisible="False" Spacing="4">
                                    <Button Classes="btn secondary sm" Content="{l:L Key=main.duplicate}"
                                            Click="OnDuplicateClicked" ToolTip.Tip="Ctrl+D" />
                                    <Button x:Name="RotateButton" Classes="btn secondary sm"
                                            Content="{l:L Key=main.rotate}"
                                            Click="OnRotateClicked" ToolTip.Tip="R" />
                                    <Button Classes="btn primary sm" Content="{l:L Key=main.delete}"
                                            Click="OnDeleteClicked" ToolTip.Tip="Suppr" />
                                </StackPanel>
                                <StackPanel x:Name="SelProperties" Spacing="6" />

                                <!-- Undo / Redo en bas (sortis du footer du concept, gardés ici par
                                     pragmatisme — le concept ne montre pas de footer Undo/Redo
                                     visible dans Editor.jsx) -->
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,12,0,0"
                                            HorizontalAlignment="Right">
                                    <Button x:Name="UndoButton" Classes="btn secondary sm"
                                            Content="{l:L Key=main.undo}"
                                            Click="OnUndoClicked" ToolTip.Tip="Ctrl+Z" />
                                    <Button x:Name="RedoButton" Classes="btn secondary sm"
                                            Content="{l:L Key=main.redo}"
                                            Click="OnRedoClicked" ToolTip.Tip="Ctrl+Y" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============================================================
             [COMPATIBILITÉ] Contrôles existants conservés hors-écran.
             Le code-behind référence ces x:Name via FindControl ; ils
             doivent exister dans l'arbre visuel pour ne pas être null.
             À recâbler dans le nouveau flux progressivement.
             ============================================================ -->
        <Border IsVisible="False">
            <StackPanel>
                <ItemsControl x:Name="DlcFilters" />
                <TextBlock x:Name="MapsCountLabel" />
                <TreeView x:Name="MapsList" SelectionChanged="OnMapSelected" />
                <TreeView x:Name="ElementsTree" SelectionChanged="OnTreeSelectionChanged" />
                <ListBox x:Name="HistoryList" SelectionChanged="OnHistoryItemSelected" />

                <Border x:Name="SessionPropsPanel">
                    <StackPanel>
                        <TextBlock x:Name="SessionRegionLabel" />
                        <TextBlock x:Name="SessionMapSizeLabel" />
                        <Slider x:Name="SessionPaSlider"
                                Minimum="64" Maximum="4096"
                                ValueChanged="OnSessionPaSliderChanged"
                                PointerWheelChanged="OnSessionPaSliderWheel" />
                        <TextBlock x:Name="SessionPaSizeLabel" />
                        <CheckBox x:Name="SessionEditPaToggle"
                                  IsCheckedChanged="OnSessionEditPaToggleChanged" />
                        <StackPanel x:Name="IssuesPanel" />
                        <NumericUpDown x:Name="PaX1Box" Increment="32" />
                        <NumericUpDown x:Name="PaY1Box" Increment="32" />
                        <NumericUpDown x:Name="PaX2Box" Increment="32" />
                        <NumericUpDown x:Name="PaY2Box" Increment="32" />
                        <Button Click="OnApplyPlayableArea" />
                        <Button Click="OnResetPlayableArea" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
