<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="using:AnnoMapEditor.Utilities"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.IslandPickerDialog"
        Title="{l:L Key=picker.title}"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ConceptInk900Brush}"
        Foreground="{DynamicResource ConceptTextBrush}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="0">

        <!-- Header (concept modale style) -->
        <Border Grid.Row="0" Padding="24,16"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="2" HorizontalAlignment="Center">
                <TextBlock Text="GALERIE" Classes="t-eyebrow" HorizontalAlignment="Center" />
                <TextBlock x:Name="Header" Classes="modal-title" />
            </StackPanel>
        </Border>

        <!-- Toolbar (filters + search + count) -->
        <Border Grid.Row="1" Padding="20,12"
                Background="{DynamicResource ConceptInk800Brush}"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <!-- Three-state filter (mutually exclusive — handled in code-behind) -->
                <StackPanel Orientation="Horizontal" Spacing="0">
                    <ToggleButton x:Name="FilterAll" Classes="btn secondary sm"
                                  Content="{l:L Key=picker.filter_all}"
                                  IsChecked="True" Click="OnFilterModeClicked"
                                  CornerRadius="4,0,0,4" />
                    <ToggleButton x:Name="FilterRandom" Classes="btn secondary sm"
                                  Content="{l:L Key=picker.filter_random}"
                                  Click="OnFilterModeClicked" CornerRadius="0" />
                    <ToggleButton x:Name="FilterFixed" Classes="btn secondary sm"
                                  Content="{l:L Key=picker.filter_fixed}"
                                  Click="OnFilterModeClicked" CornerRadius="0,4,4,0" />
                </StackPanel>

                <TextBox x:Name="FilterBox" Classes="input" Width="240"
                         Watermark="{l:L Key=picker.filter}"
                         TextChanged="OnFilterChanged" />
                <TextBlock x:Name="CountLabel"
                           Foreground="{DynamicResource ConceptTextDimBrush}"
                           FontSize="11" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Grid d'îles -->
        <ScrollViewer Grid.Row="2" Padding="16" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="Grid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Padding="20,12"
                Background="{DynamicResource ConceptInk950Brush}"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Classes="btn secondary"
                        Content="{l:L Key=picker.cancel}" Click="OnCancel" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
