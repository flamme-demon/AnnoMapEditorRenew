<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="using:AnnoMapEditor.Utilities"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.SaveModDialog"
        Title="{l:L Key=save_dialog.title}"
        Width="540" Height="240"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    <Grid RowDefinitions="*,Auto" Margin="20">
        <StackPanel Grid.Row="0" Spacing="12">
            <TextBlock Text="{l:L Key=save_dialog.name}" FontWeight="SemiBold" />
            <TextBox x:Name="NameBox" Watermark="{l:L Key=save_dialog.name_watermark}" />
            <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                       Text="{l:L Key=save_dialog.help}" />
            <TextBlock TextWrapping="Wrap" Opacity="0.5" FontSize="11"
                       Text="{l:L Key=save_dialog.warning}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="{l:L Key=save_dialog.cancel}" Click="OnCancel" />
            <Button Content="{l:L Key=save_dialog.save}" Click="OnSave" Classes="accent" />
        </StackPanel>
    </Grid>
</Window>
