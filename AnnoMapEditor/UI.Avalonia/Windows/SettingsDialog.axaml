<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="using:AnnoMapEditor.Utilities"
        x:Class="AnnoMapEditor.UI.Avalonia.Windows.SettingsDialog"
        Title="{l:L Key=settings.title}"
        Width="520" Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource ConceptInk900Brush}"
        Foreground="{DynamicResource ConceptTextBrush}">

    <Grid RowDefinitions="Auto,*,Auto" Margin="0">

        <!-- Header (concept modale style) -->
        <Border Grid.Row="0" Padding="24,20"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4" HorizontalAlignment="Center">
                <TextBlock Text="ATELIER" Classes="t-eyebrow" HorizontalAlignment="Center" />
                <TextBlock Text="{l:L Key=settings.title}" Classes="modal-title" />
                <Border Classes="divider-ornate" Width="160" Margin="0,8,0,0" />
            </StackPanel>
        </Border>

        <!-- Body : ScrollViewer simple. `HorizontalScrollBarVisibility="Disabled"`
             contraint le contenu à la largeur de la fenêtre — sans ça, le ScrollViewer
             autorisait le débordement à droite (les wrap des labels étaient ignorés
             car le contenu s'étendait à sa width naturelle). Le scrollbar vertical
             n'apparaît que si la hauteur dépasse, et hérite des couleurs concept du
             style global ScrollBar (App.axaml). -->
        <ScrollViewer Grid.Row="1" Padding="32,20"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="22">

                <!-- ── Démarrage ── -->
                <StackPanel Spacing="10">
                    <TextBlock Text="DÉMARRAGE" Classes="t-eyebrow" />
                    <CheckBox x:Name="AutoStartCheckBox"
                              IsCheckedChanged="OnAutoStartToggled"
                              Foreground="{DynamicResource ConceptTextBrush}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{l:L Key=start.autostart}" FontSize="13" />
                            <TextBlock Text="{l:L Key=start.autostart_help}"
                                       Foreground="{DynamicResource ConceptTextMuteBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </CheckBox>
                </StackPanel>

                <Border Classes="divider-ornate" />

                <!-- ── Apparence ── -->
                <StackPanel Spacing="10">
                    <TextBlock Text="APPARENCE" Classes="t-eyebrow" />

                    <Grid ColumnDefinitions="140,*">
                        <TextBlock Grid.Column="0" Text="Langue"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ConceptTextBrush}" />
                        <ComboBox Grid.Column="1" x:Name="LanguageCombo"
                                  Classes="input" HorizontalAlignment="Stretch"
                                  SelectionChanged="OnLanguageChanged">
                            <ComboBoxItem Content="English"  Tag="en" />
                            <ComboBoxItem Content="Français" Tag="fr" />
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <Border Classes="divider-ornate" />

                <!-- ── Avancé ── -->
                <StackPanel Spacing="10">
                    <TextBlock Text="AVANCÉ" Classes="t-eyebrow" />

                    <CheckBox x:Name="ExpertModeCheckBox"
                              IsCheckedChanged="OnExpertModeToggled"
                              Foreground="{DynamicResource ConceptTextBrush}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Mode expert" FontSize="13" />
                            <TextBlock Text="Active les overrides de chemins (data, mods)."
                                       Foreground="{DynamicResource ConceptTextMuteBrush}"
                                       FontSize="11" />
                        </StackPanel>
                    </CheckBox>

                    <StackPanel Spacing="6">
                        <TextBlock Text="DOSSIER DU JEU" Classes="t-eyebrow" />
                        <!-- Path read-only : Border + TextBlock plutôt qu'un TextBox.
                             Un TextBox Avalonia pose une Width naturelle plus large
                             que son parent pour les longs textes même avec
                             `TextWrapping=Wrap` + `MinWidth=0`, et le
                             ScrollContentPresenter en mode `HorizontalScrollBarVisibility=
                             Disabled` ne le contraint pas (cas observé via DevTools).
                             Un TextBlock wrap correctement dès que sa Width est bornée
                             par son parent — comportement attendu. -->
                        <Border Background="{DynamicResource ConceptInk950Brush}"
                                BorderBrush="{DynamicResource ConceptBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="12,9">
                            <TextBlock x:Name="GamePathLabel"
                                       TextWrapping="Wrap"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource ConceptTextBrush}" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,16"
                Background="{DynamicResource ConceptInk950Brush}"
                BorderBrush="{DynamicResource ConceptBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="Les changements sont enregistrés en direct."
                           Foreground="{DynamicResource ConceptTextMuteBrush}"
                           FontSize="11" FontStyle="Italic"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" Classes="btn primary"
                        Content="Fermer" Click="OnCloseClicked" />
            </Grid>
        </Border>
    </Grid>
</Window>
